# ===========================================
# HarmoniQ Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enable additional features.

# --- Database ---
DATABASE_URL=                           # [REQUIRED] PostgreSQL connection string

# --- Server ---
PORT=5000                               # [OPTIONAL] Server port (default: 5000)
NODE_ENV=development                    # [OPTIONAL] "development" or "production"
SESSION_SECRET=                         # [REQUIRED] Secret for session cookie signing

# --- Replit Auth (OpenID Connect) ---
ISSUER_URL=https://replit.com/oidc      # [REQUIRED] OIDC issuer URL
REPL_ID=                                # [REQUIRED] Replit project ID (auto-set by Replit)

# --- OpenAI (lyrics generation, AI suggestions) ---
AI_INTEGRATIONS_OPENAI_API_KEY=         # [REQUIRED] OpenAI API key (via Replit integration)
AI_INTEGRATIONS_OPENAI_BASE_URL=        # [REQUIRED] OpenAI base URL (via Replit integration)

# --- Gemini (song concepts, music theory, analysis) ---
AI_INTEGRATIONS_GEMINI_API_KEY=         # [REQUIRED] Gemini API key (via Replit integration)
AI_INTEGRATIONS_GEMINI_BASE_URL=        # [REQUIRED] Gemini base URL (via Replit integration)

# --- Replicate (MusicGen instrumentals, Bark vocals, ACE-Step) ---
REPLICATE_API_KEY=                      # [OPTIONAL] Enables MusicGen, Bark vocals, and ACE-Step

# --- Stable Audio via fal.ai (extended instrumentals) ---
FAL_API_KEY=                            # [OPTIONAL] Enables Stable Audio generation
FAL_KEY=                                # [OPTIONAL] Alias for FAL_API_KEY

# --- Suno via DefAPI (studio-quality vocals) ---
DEFAPI_API_KEY=                         # [OPTIONAL] Recommended Suno provider
DEFAPI_BASE_URL=                        # [OPTIONAL] DefAPI base URL (default: https://api.defapi.org)

# --- Suno Alternative Providers ---
SUNO_PROVIDER=                          # [OPTIONAL] Force provider: "defapi", "kie", or "sunoorg"
SUNO_API_KEY=                           # [OPTIONAL] Generic Suno API key
KIE_API_KEY=                            # [OPTIONAL] Kie.ai provider key
KIE_BASE_URL=                           # [OPTIONAL] Kie.ai base URL
SUNOAPI_COOKIE=                         # [OPTIONAL] SunoAPI.org session cookie

# --- Admin ---
ADMIN_USER_IDS=                         # [OPTIONAL] Comma-separated user IDs for unlimited credits
